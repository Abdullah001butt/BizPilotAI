# ============================================================================
#  Root environment for `docker compose`. Copy to `.env` and edit.
#  (Backend-only local runs use backend/.env instead — see backend/.env.example)
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Security (REQUIRED) ─────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_random_secret_key_before_running

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=bizpilot
POSTGRES_PASSWORD=bizpilot
POSTGRES_DB=bizpilot
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Ports ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── CORS (backend allows these origins) ─────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173

# ── First admin (auto-seeded on first backend start) ────────────────────────
SEED_ON_START=true
FIRST_SUPERUSER_EMAIL=admin@bizpilot.ai
FIRST_SUPERUSER_PASSWORD=ChangeMe123!

# ── AI Copilot (Google Gemini) — leave blank to disable ─────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Billing (Stripe) — leave blank to disable ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:5173
