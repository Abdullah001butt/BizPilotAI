# ============================================================================
#  BizPilot AI — Backend environment configuration
#  Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
DEBUG=true
PROJECT_NAME="BizPilot AI"
API_V1_PREFIX=/api/v1

# ── Security ────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_super_secret_dev_key_do_not_use_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ────────────────────────────────────────────────────────────────
# Local dev (default): SQLite (async)
DATABASE_URL=sqlite+aiosqlite:///./bizpilot.db
# Production example (Supabase / Postgres):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/bizpilot
SQL_ECHO=false

# ── CORS (comma-separated list of allowed frontend origins) ─────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── First admin user (created by `python -m app.scripts.seed`) ──────────────
FIRST_SUPERUSER_EMAIL=admin@bizpilot.ai
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
FIRST_SUPERUSER_NAME=BizPilot Admin
